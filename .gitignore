# ---------------------------------------------------------------------------
# This device tree lives INSIDE a full minimal-manifest TWRP/OmniROM build
# tree (the working directory contains build/, system/, external/, out/, ...).
# To keep the published repo limited to the files that actually belong to it,
# we ignore everything by default and then explicitly re-include our own paths.
# ---------------------------------------------------------------------------

# Ignore every top-level entry by default.
/*

# --- Re-include the repo's own files -----------------------------------------
!/.gitignore
!/README.md
!/LICENSE
!/CONTRIBUTING.md
!/.github/
!/screenshots/
!/patch_touch_clean.sh
!/xiaomi_touch_common_patched.ko

# tools/ is also an AOSP build dir — track only our own utility, nothing else.
!/tools/
/tools/*
!/tools/slot_switch.py

# --- TWRP device tree --------------------------------------------------------
# Re-include device/, but only the xiaomi/degas branch (other vendors that the
# build tree drops into device/ are not part of this repo).
!/device/
/device/*
!/device/xiaomi/
/device/xiaomi/*
!/device/xiaomi/degas/

# --- Local-only working files / build artifacts ------------------------------
# Built recovery images belong in GitHub Releases, not in git history.
/twrp_degas-vendor_boot*.img
*.log
